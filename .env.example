# Required. OpenRouter API key used by scripts/enhance-post-agent.js.
OPENROUTER_API_KEY=

# Browser analytics defaults to disabled. Use test-property IDs for local/test builds.
VITE_ANALYTICS_ENABLED=false
VITE_ANALYTICS_ENVIRONMENT=local
VITE_ANALYTICS_ALLOWED_HOSTS=localhost,127.0.0.1
VITE_ANALYTICS_GA4_MEASUREMENT_ID=
VITE_ANALYTICS_CLARITY_PROJECT_ID=
VITE_ANALYTICS_CONSENT_REQUIRED=true
VITE_ANALYTICS_CONSENT_STORAGE_KEY=blog.analyticsConsent
VITE_ANALYTICS_POLICY_VERSION=1

# Metadata and crawler policy. Test/local builds should remain non-indexable.
VITE_SITE_URL=http://localhost:8080
VITE_ROBOTS_INDEX=false

# Optional overrides (see DEFAULT_CONFIG in scripts/enhance-post-agent.js).
# MODEL=meta-llama/llama-3.3-70b-instruct:free
# TEMPERATURE=0.7
# MAX_STEPS=10
# ENHANCEMENT_MODE=complete
# MAX_FILES=10
# OUTPUT_MODE=new_file
# DRY_RUN=false
# DEBUG=false
